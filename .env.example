# Database
# For Docker: DATABASE_URL=postgresql://nadc:nadc_secret@localhost:5432/nadc_helpdesk
# For local PostgreSQL (default install):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nadc_helpdesk

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# JWT
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMTP (outbound email)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=helpdesk@yourdomain.com

# IMAP (inbound email-to-ticket)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
