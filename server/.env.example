# ============================================
# NADC Helpdesk Server Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED - Core Settings
# ============================================

# Database connection string
DATABASE_URL=postgresql://nadc:nadc_secret@localhost:5432/nadc_helpdesk

# JWT secrets - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# JWT expiration times
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server port
PORT=3001

# Client URL (for CORS and email links)
CLIENT_URL=http://localhost:5173

# Environment
NODE_ENV=development

# ============================================
# OPTIONAL - File Uploads
# ============================================

# Upload directory (relative to server root)
UPLOAD_DIR=./uploads

# Maximum file size in MB
MAX_FILE_SIZE_MB=10

# ============================================
# OPTIONAL - Email (SMTP)
# ============================================
# Configure these to enable outbound email notifications
# Email settings can also be configured in the UI under Settings

# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=helpdesk@yourcompany.com
# SMTP_PASS=your-email-password
# SMTP_FROM=helpdesk@yourcompany.com

# ============================================
# OPTIONAL - Inbound Email (IMAP)
# ============================================
# Configure these to enable email-to-ticket functionality

# IMAP_HOST=imap.office365.com
# IMAP_PORT=993
# IMAP_USER=tickets@yourcompany.com
# IMAP_PASS=your-imap-password

# ============================================
# OPTIONAL - Google Reviews Integration
# ============================================

# Google review URL (from your Google Business profile)
# GOOGLE_REVIEW_URL=https://g.page/r/YOUR-REVIEW-LINK/review

# Days between review requests for same contact
REVIEW_COOLDOWN_DAYS=90

# Hours to wait after ticket closure before sending review request
REVIEW_SEND_DELAY_HOURS=24

# ============================================
# OPTIONAL - Alternative URL for email links
# ============================================
# If different from CLIENT_URL (e.g., public-facing domain)
# HELPDESK_URL=https://helpdesk.yourcompany.com
